{
  "name": "@zethictech/react-native-update-gate",
  "version": "0.2.3",
  "description": "Beautiful, type-safe, server-driven force/suggest update gate for React Native. Uses Google Play's native immediate flow on Android; ships a polished animated modal on iOS.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "react-native-update-gate.podspec",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "!**/__tests__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "keywords": [
    "react-native",
    "in-app-updates",
    "force-update",
    "play-core",
    "app-store",
    "play-store",
    "version-check",
    "update-prompt"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZethicTech/react-native-update-gate.git"
  },
  "author": "Zethic Tech",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ZethicTech/react-native-update-gate/issues"
  },
  "homepage": "https://github.com/ZethicTech/react-native-update-gate#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "@react-native-community/blur": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-community/blur": {
      "optional": true
    }
  },
  "dependencies": {
    "compare-versions": "^6.1.1"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.76.0",
    "@testing-library/react-native": "^12.7.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.0",
    "jest": "^29.7.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-builder-bob": "^0.32.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  }
}
